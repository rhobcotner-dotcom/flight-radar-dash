# FlightRadar24 API token — only needed for the optional STL airport board
FR24_API_TOKEN=

# Use sandbox endpoints during development (may be unavailable — use false for live data)
FR24_USE_SANDBOX=false

# Optional: set FR24_ENABLE_PULLS=true to allow FR24 airport pulls on Netlify/deployed hosts.
# Unset = automatic (local dev only).

# Local API server port
PORT=3001

# Live map data (free, no key required)
ADSB_API_BASE=https://api.adsb.lol
# Cache ADSB point queries (ms). Default 30s reduces upstream load during auto-refresh.
ADSB_CACHE_TTL_MS=30000
# Serve cached ADSB data up to 5 min when upstream rate-limits (429/420).
ADSB_STALE_MAX_MS=300000
ADSB_COOLDOWN_MS=90000
ADSB_MIN_INTERVAL_MS=8000
# Optional OpenSky credentials — without these, the map uses ADSB.lol only (avoids OpenSky 429s).
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
# OPENSKY_CACHE_TTL_MS=30000
# OPENSKY_COOLDOWN_MS=90000
ROUTE_API_BASE=https://api.adsbdb.com/v0
# Optional: override User-Agent for Planespotters / Wikipedia photo lookups
# AIRCRAFT_PHOTO_USER_AGENT=FlightRadarDash/1.0 (+https://example.com/contact)
# ADSBDB_API_BASE=https://api.adsbdb.com/v0
ROUTE_CACHE_TTL_MS=3600000
ROUTE_LOOKUP_LIMIT=120
REGISTRY_LOOKUP_LIMIT=120

# SQLite path for trend snapshots
DB_PATH=./data/snapshots.sqlite

# In-memory cache TTL for FR24 responses (ms). 0 = no cache (default for manual refresh).
CACHE_TTL_MS=0

# Radar overlay: iem (default, US NEXRAD ~5m lag) or rainviewer (global mosaic ~10m frames)
RADAR_SOURCE=iem
# How often the client re-checks for newer radar tiles (ms). Default: 90000 (iem) / 180000 (rainviewer)
# RADAR_REFRESH_MS=90000

# Optional: MetroLink / MetroBus live vehicle positions (request key at metrolinktrains.com GTFS-RT access)
METRO_API_KEY=

# Optional: Chicago Metra commuter rail GTFS-RT (request token at metra.com/metra-gtfs-api)
# METRA_API_TOKEN=

# Optional: Bay Area / California regional rail via 511.org (free key at api.511.org)
# API_511_KEY=

# Optional: RailState freight train sightings (commercial — request token at support+api@railstate.com)
# RAILSTATE_API_TOKEN=
# RAILSTATE_API_BASE=https://api.railstate.com
# RAILSTATE_SIGHTINGS_PATH=/export/full_sightings

# Optional: extra public crossing-sensor ArcGIS feeds (JSON array; Houston Train Watch is built in)
# FREIGHT_CROSSING_FEEDS=[{"id":"houston-train-watch","name":"Houston Train Watch","url":"https://services.arcgis.com/NummVBqZSIJKUeVR/arcgis/rest/services/Train_CrossingStatus_Public_Current/FeatureServer/0/query","statusField":"crossingStatus","activeValues":["blocked"],"streetField":"street","codeField":"code","movementField":"trainMovement","directionField":"direction"}]

# Optional: ham APRS positions (free at aprs.fi → account settings). Best open source for freight near STL.
APRS_FI_API_KEY=
# Optional: your ham callsign for direct APRS-IS TCP (passcode computed automatically from callsign)
# APRS_CALLSIGN=
# Optional: override computed APRS passcode
# APRS_PASSCODE=

# Highball train aggregator — auto-provisions a free key to data/highball.key on first run (passenger today)
# HIGHBALL_API_KEY=
# HIGHBALL_AUTO_KEY=false

# Optional: extra AIS via AISHub if you operate a contributing AIS station
# AISHUB_USERNAME=

AIRNOW_API_KEY=
FAA_NMS_CLIENT_ID=
FAA_NMS_CLIENT_SECRET=
NASA_FIRMS_MAP_KEY=

# Optional live map layers
EBIRD_API_KEY=

# Optional: extra camera coverage via Road511 if you already have a key (not required)
# ROAD511_API_KEY=

# Optional: 511WI developer API key (not required — app uses the public list/getdata feed)
# WI511_API_KEY=

# Optional: Windy Webcams API for additional US sky/landscape cameras (free tier at windy.com/webcams/api)
# WINDY_WEBCAMS_API_KEY=
