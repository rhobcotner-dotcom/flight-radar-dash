# FlightRadar24 API token from https://fr24api.flightradar24.com/key-management
FR24_API_TOKEN=

# Use sandbox endpoints during development (no credits consumed)
FR24_USE_SANDBOX=true

# Local API server port
PORT=3001

# SQLite path for trend snapshots
DB_PATH=./data/snapshots.sqlite

# In-memory cache TTL for live FR24 responses (ms)
CACHE_TTL_MS=45000
